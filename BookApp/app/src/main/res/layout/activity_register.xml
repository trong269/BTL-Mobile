<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_background"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="26dp"
        android:paddingTop="34dp"
        android:paddingRight="26dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:text="Tạo tài khoản"
            android:textColor="#8E4E12"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Tạo tài khoản cá nhân để bắt đầu hành trình đọc sách."
            android:textColor="#6E4A2D"
            android:textSize="20sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="TÊN TÀI KHOẢN"
            android:textColor="#5F3B1F"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtRegisterUsername"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/auth_input_bg"
            android:hint="Nhập tên tài khoản"
            android:inputType="text"
            android:paddingHorizontal="14dp"
            android:textColor="@color/text_input"
            android:textColorHint="@color/text_muted"
            android:textSize="17sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="EMAIL"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtRegisterEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/auth_input_bg"
            android:hint="Nhập email"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="14dp"
            android:textColor="@color/text_input"
            android:textColorHint="@color/text_muted"
            android:textSize="17sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="MẬT KHẨU"
            android:textColor="#5F3B1F"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtRegisterPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/auth_input_bg"
            android:hint="Tối thiểu 6 ký tự"
            android:inputType="textPassword"
            android:paddingHorizontal="14dp"
            android:textColor="@color/text_input"
            android:textColorHint="@color/text_muted"
            android:textSize="17sp" />

        <EditText
            android:id="@+id/edtRegisterConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/auth_input_bg"
            android:hint="Nhập lại mật khẩu"
            android:inputType="textPassword"
            android:paddingHorizontal="14dp"
            android:textColor="@color/text_input"
            android:textColorHint="@color/text_muted"
            android:textSize="17sp" />

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/auth_primary_button_bg"
            android:text="Đăng ký"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvGoToLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="22dp"
            android:text="Đã có tài khoản? Đăng nhập ngay"
            android:textColor="#7A4311"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>