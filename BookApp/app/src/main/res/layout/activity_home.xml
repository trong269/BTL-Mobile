<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_background"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="16dp"
                android:paddingTop="16dp"
                android:paddingRight="16dp"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="||"
                    android:textColor="#7A4A1A"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:fontFamily="serif"
                    android:text="Khám phá"
                    android:textColor="#6D3B0B"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="o"
                    android:textColor="#7A4A1A"
                    android:textSize="18sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="4dp"
                android:layout_marginRight="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/edtSearch"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/home_card_bg"
                    android:hint="Tìm theo tên sách hoặc tác giả"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingHorizontal="14dp"
                    android:singleLine="true"
                    android:textColor="#4A2D12"
                    android:textColorHint="#9A7D60" />

                <ImageButton
                    android:id="@+id/btnSearchIcon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/home_primary_button_bg"
                    android:contentDescription="Search"
                    android:padding="12dp"
                    android:src="@android:drawable/ic_menu_search"
                    android:tint="@android:color/white" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginRight="16dp"
                android:background="@drawable/home_card_bg"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:text="Nổi bật tháng này"
                    android:textAllCaps="true"
                    android:textColor="#8A6A48"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="serif"
                    android:text="Thánh đường tĩnh lặng"
                    android:textColor="#24190F"
                    android:textSize="36sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Tuyển tập giàu chiều sâu cho những phiên đọc tập trung và thư thái."
                    android:textColor="#816140"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnContinueRead"
                    android:layout_width="150dp"
                    android:layout_height="46dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/home_primary_button_bg"
                    android:text="Bắt đầu đọc"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginRight="16dp"
                android:fontFamily="serif"
                android:text="Danh mục chọn lọc"
                android:textColor="#25190F"
                android:textSize="28sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <Button
                        android:id="@+id/btnLibrary"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:background="@drawable/home_chip_bg"
                        android:minWidth="0dp"
                        android:paddingHorizontal="14dp"
                        android:text="Thư viện"
                        android:textAllCaps="false"
                        android:textColor="#6B3C10"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnCategories"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/home_chip_bg"
                        android:minWidth="0dp"
                        android:paddingHorizontal="14dp"
                        android:text="Thể loại"
                        android:textAllCaps="false"
                        android:textColor="#6B3C10"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btnFavorites"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/home_chip_bg"
                        android:minWidth="0dp"
                        android:paddingHorizontal="14dp"
                        android:text="Yêu thích"
                        android:textAllCaps="false"
                        android:textColor="#6B3C10"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btnHistory"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/home_chip_bg"
                        android:minWidth="0dp"
                        android:paddingHorizontal="14dp"
                        android:text="Lịch sử"
                        android:textAllCaps="false"
                        android:textColor="#6B3C10"
                        android:textSize="13sp" />
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="18dp"
                android:layout_marginRight="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="serif"
                    android:text="Sách mới"
                    android:textColor="#25190F"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnSeeAllRecommended"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xem tất cả"
                    android:textColor="#7A4715"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerBooks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="10dp" />

            <TextView
                android:id="@+id/tvBooksError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginRight="16dp"
                android:textColor="#B43A2D"
                android:textSize="13sp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginRight="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnPrevPage"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:background="@drawable/home_chip_bg"
                    android:text="Trước"
                    android:textAllCaps="false"
                    android:textColor="#6B3C10"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPageIndicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10dp"
                    android:text="Trang 1/1"
                    android:textColor="#6C4C2A"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnNextPage"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:background="@drawable/home_chip_bg"
                    android:text="Sau"
                    android:textAllCaps="false"
                    android:textColor="#6B3C10"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginRight="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="serif"
                    android:text="Bảng xếp hạng"
                    android:textColor="#25190F"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/home_card_bg"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <Button
                        android:id="@+id/btnTopWeekTab"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:background="@drawable/home_primary_button_bg"
                        android:minWidth="0dp"
                        android:paddingHorizontal="12dp"
                        android:text="Tuần"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnTopMonthTab"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/home_chip_bg"
                        android:minWidth="0dp"
                        android:paddingHorizontal="12dp"
                        android:text="Tháng"
                        android:textAllCaps="false"
                        android:textColor="#6B3C10"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvTopDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="6dp"
                android:layout_marginRight="16dp"
                android:text="Top sách được cập nhật từ dữ liệu đọc thực tế"
                android:textColor="#886B4B"
                android:textSize="12sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerTopBooks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="16dp" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="74dp"
        android:background="#FFF9F1E6"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="10dp">

        <Button
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/home_chip_bg"
            android:text="Trang chủ"
            android:textAllCaps="false"
            android:textColor="@color/home_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/navExplore"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/home_card_bg"
            android:text="Khám phá"
            android:textAllCaps="false"
            android:textColor="#7A5A38"
            android:textSize="12sp" />

        <Button
            android:id="@+id/navLibrary"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/home_card_bg"
            android:text="Thư viện"
            android:textAllCaps="false"
            android:textColor="#7A5A38"
            android:textSize="12sp" />

        <Button
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/home_card_bg"
            android:text="Tài khoản"
            android:textAllCaps="false"
            android:textColor="#7A5A38"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
