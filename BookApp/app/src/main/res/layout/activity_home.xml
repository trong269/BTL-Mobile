<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_background"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/home_header_bg"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BookApp"
                    android:textColor="@android:color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Doc sach moi ngay, mo rong tri thuc"
                    android:textColor="#E6FFFFFF"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/edtSearch"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/home_card_bg"
                        android:drawableStart="@android:drawable/ic_menu_search"
                        android:drawablePadding="10dp"
                        android:hint="Tim sach, tac gia, the loai..."
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1"
                        android:paddingHorizontal="14dp"
                        android:singleLine="true"
                        android:textColor="#212121"
                        android:textColorHint="#6D6D6D" />

                    <ImageButton
                        android:id="@+id/btnSearchIcon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/home_primary_button_bg"
                        android:contentDescription="Nut tim kiem"
                        android:src="@android:drawable/ic_menu_search"
                        android:scaleType="centerInside"
                        android:tint="@android:color/white" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnContinueRead"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/home_primary_button_bg"
                    android:text="Tiep tuc doc"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="16dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Danh muc nhanh"
                    android:textColor="#1B1F24"
                    android:textSize="17sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <Button
                        android:id="@+id/btnLibrary"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:background="@drawable/home_chip_bg"
                        android:minWidth="0dp"
                        android:paddingHorizontal="16dp"
                        android:text="Thu vien"
                        android:textAllCaps="false"
                        android:textColor="#1D2A52"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnCategories"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/home_chip_bg"
                        android:minWidth="0dp"
                        android:paddingHorizontal="16dp"
                        android:text="The loai"
                        android:textAllCaps="false"
                        android:textColor="#1D2A52"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnFavorites"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/home_chip_bg"
                        android:minWidth="0dp"
                        android:paddingHorizontal="16dp"
                        android:text="Yeu thich"
                        android:textAllCaps="false"
                        android:textColor="#1D2A52"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnHistory"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/home_chip_bg"
                        android:minWidth="0dp"
                        android:paddingHorizontal="16dp"
                        android:text="Lich su"
                        android:textAllCaps="false"
                        android:textColor="#1D2A52"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sach cua ban"
                        android:textColor="#1B1F24"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Goi y dua tren xu huong doc cua ban"
                        android:textColor="#6A7482"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btnSeeAllRecommended"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xem tat ca"
                    android:textColor="@color/home_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerBooks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="10dp" />

            <TextView
                android:id="@+id/tvBooksError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:textColor="#D32F2F"
                android:textSize="13sp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnPrevPage"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/home_chip_bg"
                    android:text="Trang truoc"
                    android:textAllCaps="false"
                    android:textColor="#1D2A52"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPageIndicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:text="Trang 1/1"
                    android:textColor="#3F4A57"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnNextPage"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/home_chip_bg"
                    android:text="Trang sau"
                    android:textAllCaps="false"
                    android:textColor="#1D2A52"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bang xep hang"
                    android:textColor="#1B1F24"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/home_card_bg"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <Button
                        android:id="@+id/btnTopWeekTab"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:background="@drawable/home_primary_button_bg"
                        android:minWidth="0dp"
                        android:paddingHorizontal="14dp"
                        android:text="Top tuan"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnTopMonthTab"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/home_chip_bg"
                        android:minWidth="0dp"
                        android:paddingHorizontal="14dp"
                        android:text="Top thang"
                        android:textAllCaps="false"
                        android:textColor="#1D2A52"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvTopDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="6dp"
                android:text="Cap nhat xu huong trong 7 ngay gan nhat"
                android:textColor="#6A7482"
                android:textSize="12sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerTopBooks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="16dp" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp">

        <Button
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/home_chip_bg"
            android:text="Home"
            android:textAllCaps="false"
            android:textColor="@color/home_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/navExplore"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/home_card_bg"
            android:text="Kham pha"
            android:textAllCaps="false"
            android:textColor="#4E5762"
            android:textSize="12sp" />

        <Button
            android:id="@+id/navLibrary"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/home_card_bg"
            android:text="Thu vien"
            android:textAllCaps="false"
            android:textColor="#4E5762"
            android:textSize="12sp" />

        <Button
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/home_card_bg"
            android:text="Tai khoan"
            android:textAllCaps="false"
            android:textColor="#4E5762"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
