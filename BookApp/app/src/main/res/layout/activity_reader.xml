<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/readerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFDFD">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/readerScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <TextView
            android:id="@+id/tvReaderContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="7dp"
            android:paddingStart="24dp"
            android:paddingTop="98dp"
            android:paddingEnd="24dp"
            android:paddingBottom="190dp"
            android:textColor="#121212"
            android:textSize="18sp" />
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/readerTopBar"
        android:layout_width="match_parent"
        android:layout_height="86dp"
        android:background="#F2FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="22dp"
        android:paddingEnd="8dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/btnReaderClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="Đóng"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#0041F7" />

        <TextView
            android:id="@+id/tvReaderBookTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="#101418"
            android:textSize="21sp"
            android:textStyle="bold" />

        <View
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:visibility="invisible" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/readerBottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#F4FFFFFF"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvReaderChapterTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLines="1"
                android:textColor="#30363C"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvReaderChapterMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#8A9099"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvReaderChapterCounter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1/1"
                android:textColor="#6E7681"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seekReaderProgress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="0"
                android:thumbTint="#1F8BD3"
                android:progressTint="#1F8BD3" />

            <TextView
                android:id="@+id/tvReaderProgressPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="#6E7681"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnReaderPrev"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginHorizontal="8dp"
                android:background="@android:color/transparent"
                android:contentDescription="Chương trước"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#2A79B9" />

            <ImageButton
                android:id="@+id/btnReaderSettings"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginHorizontal="8dp"
                android:background="@android:color/transparent"
                android:contentDescription="Setting"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="#0041F7" />

            <ImageButton
                android:id="@+id/btnReaderPlay"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginHorizontal="8dp"
                android:background="@android:color/transparent"
                android:contentDescription="Play"
                android:src="@android:drawable/ic_media_play"
                app:tint="#2A79B9" />

            <ImageButton
                android:id="@+id/btnReaderList"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginHorizontal="8dp"
                android:background="@android:color/transparent"
                android:contentDescription="Danh sách chương"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="#0041F7" />

            <ImageButton
                android:id="@+id/btnReaderNext"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginHorizontal="8dp"
                android:background="@android:color/transparent"
                android:contentDescription="Chương tiếp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#2A79B9" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
