<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnProfileBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/home_chip_bg"
                android:contentDescription="Back"
                android:padding="8dp"
                android:src="@android:drawable/ic_media_previous" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Tai khoan"
                android:textColor="#1B1F24"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/home_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thong tin ca nhan"
                android:textColor="#1B1F24"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Ho va ten"
                android:textColor="#4E5762"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/edtProfileFullName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/home_chip_bg"
                android:hint="Nhap ho va ten"
                android:inputType="textPersonName"
                android:paddingHorizontal="12dp"
                android:textColor="#212121"
                android:textColorHint="#6D6D6D" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Ten dang nhap"
                android:textColor="#4E5762"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/edtProfileUsername"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/home_chip_bg"
                android:hint="Nhap ten dang nhap"
                android:inputType="textPersonName"
                android:paddingHorizontal="12dp"
                android:textColor="#212121"
                android:textColorHint="#6D6D6D" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Email"
                android:textColor="#4E5762"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/edtProfileEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/home_chip_bg"
                android:hint="Nhap email"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="12dp"
                android:textColor="#212121"
                android:textColorHint="#6D6D6D" />

            <Button
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/home_primary_button_bg"
                android:text="Luu thong tin"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/home_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Doi mat khau"
                android:textColor="#1B1F24"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Mat khau hien tai"
                android:textColor="#4E5762"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/edtCurrentPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/home_chip_bg"
                android:hint="Nhap mat khau hien tai"
                android:inputType="textPassword"
                android:paddingHorizontal="12dp"
                android:textColor="#212121"
                android:textColorHint="#6D6D6D" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Mat khau moi"
                android:textColor="#4E5762"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/edtNewPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/home_chip_bg"
                android:hint="Nhap mat khau moi"
                android:inputType="textPassword"
                android:paddingHorizontal="12dp"
                android:textColor="#212121"
                android:textColorHint="#6D6D6D" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Xac nhan mat khau moi"
                android:textColor="#4E5762"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/edtConfirmNewPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/home_chip_bg"
                android:hint="Nhap lai mat khau moi"
                android:inputType="textPassword"
                android:paddingHorizontal="12dp"
                android:textColor="#212121"
                android:textColorHint="#6D6D6D" />

            <Button
                android:id="@+id/btnChangePassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/home_primary_button_bg"
                android:text="Doi mat khau"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/home_chip_bg"
            android:text="Dang xuat"
            android:textAllCaps="false"
            android:textColor="#B3261E"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>
