<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_background"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/library_header_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <ImageButton
                android:id="@+id/btnProfileBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:contentDescription="Quay lai"
                android:padding="8dp"
                android:src="@android:drawable/ic_media_previous"
                android:tint="@android:color/white" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:text="Tai khoan"
                    android:textColor="@android:color/white"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thong tin ca nhan va bao mat"
                    android:textColor="#FFEBD3B5"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/home_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="Ho so ca nhan"
                android:textColor="#4A2D12"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="HO VA TEN"
                android:textColor="#7E6142"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtProfileFullName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/auth_input_bg"
                android:hint="Nhap ho va ten"
                android:inputType="textPersonName"
                android:paddingHorizontal="12dp"
                android:textColor="#4A2D12"
                android:textColorHint="#9A7D60" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="TEN TAI KHOAN"
                android:textColor="#7E6142"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtProfileUsername"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/auth_input_bg"
                android:hint="Nhap ten tai khoan"
                android:inputType="textPersonName"
                android:paddingHorizontal="12dp"
                android:textColor="#4A2D12"
                android:textColorHint="#9A7D60" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="EMAIL"
                android:textColor="#7E6142"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtProfileEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/auth_input_bg"
                android:hint="Nhap email"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="12dp"
                android:textColor="#4A2D12"
                android:textColorHint="#9A7D60" />

            <Button
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/home_primary_button_bg"
                android:text="Luu thong tin"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/home_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="Bao mat"
                android:textColor="#4A2D12"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="MAT KHAU HIEN TAI"
                android:textColor="#7E6142"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtCurrentPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/auth_input_bg"
                android:hint="Nhap mat khau hien tai"
                android:inputType="textPassword"
                android:paddingHorizontal="12dp"
                android:textColor="#4A2D12"
                android:textColorHint="#9A7D60" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="MAT KHAU MOI"
                android:textColor="#7E6142"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtNewPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/auth_input_bg"
                android:hint="Nhap mat khau moi"
                android:inputType="textPassword"
                android:paddingHorizontal="12dp"
                android:textColor="#4A2D12"
                android:textColorHint="#9A7D60" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="XAC NHAN MAT KHAU"
                android:textColor="#7E6142"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtConfirmNewPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/auth_input_bg"
                android:hint="Nhap lai mat khau moi"
                android:inputType="textPassword"
                android:paddingHorizontal="12dp"
                android:textColor="#4A2D12"
                android:textColorHint="#9A7D60" />

            <Button
                android:id="@+id/btnChangePassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/home_primary_button_bg"
                android:text="Cap nhat mat khau"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/btn_outline_bg"
            android:text="Dang xuat"
            android:textAllCaps="false"
            android:textColor="#8D4312"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>
