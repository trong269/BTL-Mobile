<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_background"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/library_header_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <ImageButton
                android:id="@+id/btnProfileBack"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/back_round_bg"
                android:contentDescription="Quay lại"
                android:padding="5dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_back_arrow" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:text="Tài khoản"
                    android:textColor="@android:color/white"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thông tin cá nhân và bảo mật"
                    android:textColor="#FFEBD3B5"
                    android:textSize="12sp" />
            </LinearLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchThemeMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                app:switchMinWidth="52dp"
                app:thumbTint="@color/home_primary"
                app:trackTint="@color/home_chip_bg" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/home_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="Hồ sơ cá nhân"
                android:textColor="#4A2D12"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="HO VA TEN"
                android:textColor="#7E6142"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtProfileFullName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/auth_input_bg"
                android:hint="Nhập họ và tên"
                android:inputType="textPersonName"
                android:paddingHorizontal="12dp"
                android:textColor="#4A2D12"
                android:textColorHint="#9A7D60" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="TÊN TÀI KHOẢN"
                android:textColor="#7E6142"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtProfileUsername"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/auth_input_bg"
                android:hint="Nhập tên tài khoản"
                android:inputType="textPersonName"
                android:paddingHorizontal="12dp"
                android:textColor="#4A2D12"
                android:textColorHint="#9A7D60" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="EMAIL"
                android:textColor="#7E6142"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtProfileEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/auth_input_bg"
                android:hint="Nhập email"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="12dp"
                android:textColor="#4A2D12"
                android:textColorHint="#9A7D60" />

            <Button
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/home_primary_button_bg"
                android:text="Lưu thông tin"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/home_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="Bảo mật"
                android:textColor="#4A2D12"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="MẬT KHẨU HIỆN TẠI"
                android:textColor="#7E6142"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtCurrentPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/auth_input_bg"
                android:hint="Nhập mật khẩu hiện tại"
                android:inputType="textPassword"
                android:paddingHorizontal="12dp"
                android:textColor="#4A2D12"
                android:textColorHint="#9A7D60" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="MẬT KHẨU MỚI"
                android:textColor="#7E6142"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtNewPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/auth_input_bg"
                android:hint="Nhập mật khẩu mới"
                android:inputType="textPassword"
                android:paddingHorizontal="12dp"
                android:textColor="#4A2D12"
                android:textColorHint="#9A7D60" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="XÁC NHẬN MẬT KHẨU"
                android:textColor="#7E6142"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtConfirmNewPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/auth_input_bg"
                android:hint="Nhập lại mật khẩu mới"
                android:inputType="textPassword"
                android:paddingHorizontal="12dp"
                android:textColor="#4A2D12"
                android:textColorHint="#9A7D60" />

            <Button
                android:id="@+id/btnChangePassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/home_primary_button_bg"
                android:text="Cập nhật mật khẩu"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/btn_outline_bg"
            android:text="Đăng xuất"
            android:textAllCaps="false"
            android:textColor="#8D4312"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>
