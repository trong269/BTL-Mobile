<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/home_card_bg"
    android:elevation="3dp"
    android:orientation="horizontal"
    android:padding="12dp">

    <ImageView
        android:id="@+id/ivCatalogCover"
        android:layout_width="80dp"
        android:layout_height="110dp"
        android:background="@drawable/book_cover_placeholder"
        android:scaleType="centerCrop"
        android:contentDescription="Anh bia sach" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvCatalogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:textColor="#1B1F24"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCatalogAuthor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:maxLines="1"
            android:textColor="#68707A"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvCatalogCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/chip_unselected_bg"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:textColor="#23408E"
            android:textSize="11sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvCatalogRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@android:drawable/star_on"
                android:drawablePadding="3dp"
                android:gravity="center_vertical"
                android:textColor="#F9A825"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCatalogChapters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:textColor="#9099A4"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvCatalogDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:maxLines="2"
            android:textColor="#9099A4"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
