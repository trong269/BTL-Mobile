<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_background"
    android:orientation="vertical">

    <!-- Header tìm kiếm -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/home_header_bg"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnCatalogBack"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/back_round_bg"
                android:contentDescription="Quay lại"
                android:padding="5dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_back_arrow" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Danh mục sách"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <EditText
            android:id="@+id/edtCatalogSearch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/home_card_bg"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="10dp"
            android:hint="Tìm kiếm sách, tác giả, thể loại, ..."
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:paddingHorizontal="14dp"
            android:textColor="#212121"
            android:textColorHint="#6D6D6D"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Tab filter thể loại -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="10dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/llCategoryTabs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp" />
    </HorizontalScrollView>

    <!-- Filter options -->
    <!-- Removed - now using Dialog -->

    <!-- Filter toggle button -->
    <Button
        android:id="@+id/btnToggleFilter"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/home_chip_bg"
        android:text="Bộ lọc"
        android:textAllCaps="false"
        android:textColor="#23408E"
        android:textSize="12sp"
        android:textStyle="bold" />

    <!-- Kết quả + Loading -->
    <TextView
        android:id="@+id/tvCatalogStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="4dp"
        android:textColor="#9099A4"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Danh sách sách -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCatalog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingVertical="4dp"
        android:clipToPadding="false" />

    <!-- Phân trang -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:layout_marginHorizontal="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCatalogPrev"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/home_chip_bg"
            android:text="&lt; Trang trước"
            android:textAllCaps="false"
            android:textColor="#23408E"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCatalogPage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:text="1/1"
            android:textColor="#3F4A57"
            android:textSize="13sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCatalogNext"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/home_chip_bg"
            android:text="Trang sau &gt;"
            android:textAllCaps="false"
            android:textColor="#23408E"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
