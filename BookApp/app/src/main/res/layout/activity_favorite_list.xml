<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_background"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/library_header_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageButton
            android:id="@+id/btnFavoriteListBack"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/back_round_bg"
            android:contentDescription="Quay lại"
            android:padding="5dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_back_arrow" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Danh sách yêu thích"
                android:textColor="@android:color/white"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Tất cả sách bạn đã đánh dấu yêu thích"
                android:textColor="#FFEED9C0"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/library_stat_card_bg"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tổng sách yêu thích"
            android:textColor="#7A5A39"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvFavoriteListCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="0"
            android:textColor="#6B3C10"
            android:textSize="26sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerFavoriteList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:background="@drawable/library_section_card_bg"
        android:clipToPadding="false"
        android:nestedScrollingEnabled="false"
        android:padding="10dp" />

    <TextView
        android:id="@+id/tvFavoriteListEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="Danh sách yêu thích đang trống. Bạn hãy thêm sách yêu thích từ trang chi tiết sách."
        android:textColor="#886B4B"
        android:textSize="13sp"
        android:visibility="gone" />

</LinearLayout>
