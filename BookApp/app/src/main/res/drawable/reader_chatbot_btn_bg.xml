<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:centerColor="#40FFDF9A"
                android:endColor="#00FFDF9A"
                android:gradientRadius="22dp"
                android:startColor="#66FFE8B8"
                android:type="radial" />
        </shape>
    </item>

    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:endColor="#FF8B4A00"
                android:startColor="#FFFFD27A" />
            <stroke
                android:width="1dp"
                android:color="#FFEBC07B" />
        </shape>
    </item>
</layer-list>
