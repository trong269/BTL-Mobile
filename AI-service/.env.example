# =============================
# App Settings
# =============================
APP_HOST=0.0.0.0
APP_PORT=8000

# =============================
# LLM Provider Selection
# Chọn 1 trong: gemini | openai | local | ollama
# =============================
LLM_PROVIDER=gemini

# temperature (0.0-2.0): càng thấp càng chính xác, càng cao càng sáng tạo
LLM_TEMPERATURE=0.7

# top_p (0.0-1.0): phạm vi lựa chọn token — 1.0 = không giới hạn, 0.1 = rất chọn lọc
LLM_TOP_P=0.9

# max_tokens: số token tối đa trong câu trả lời
LLM_MAX_TOKENS=2048

# =============================
# Google Gemini  (LLM_PROVIDER=gemini)
# =============================
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# =============================
# OpenAI         (LLM_PROVIDER=openai)
# =============================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# =============================
# Local model    (LLM_PROVIDER=local)
# Tương thích OpenAI API: LM Studio, vLLM, llama.cpp server...
# =============================
LOCAL_BASE_URL=http://localhost:1234/v1
LOCAL_MODEL=local-model
LOCAL_API_KEY=not-needed

# =============================
# Ollama local   (LLM_PROVIDER=ollama)
# =============================
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
